{
    "singleQuote": false,
    "trailingComma": "es5",
    "semi": true,
    "tabWidth": 4,
    "importOrder": [
        "^react",
        "^next",
        "^next/(.*)$",
        "<THIRD_PARTY_MODULES>",
        "^@[^/](.*)$",
        "^@/(.*)$",
        "^[./]"
    ],
    "importOrderSeparation": false,
    "importOrderSortSpecifiers": true,
    "plugins": [
        "@trivago/prettier-plugin-sort-imports",
        "prettier-plugin-tailwindcss"
    ]
}